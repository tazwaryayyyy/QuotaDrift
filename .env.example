# Groq — fastest free inference, best primary
# https://console.groq.com/keys
GROQ_API_KEY=gsk_your_key_here

# GitHub Models — your personal access token (no scopes needed)
# https://github.com/settings/tokens → Fine-grained → Generate
GITHUB_TOKEN=ghp_your_token_here

# Mistral AI — free tier (1B tokens/month)
# https://console.mistral.ai/api-keys/
MISTRAL_API_KEY=your_key_here

# Silicon Flow — OpenAI-compatible, 20M tokens free
# https://cloud.siliconflow.cn/account/ak
SILICONFLOW_API_KEY=your_key_here
# Optional: if you need to set custom base URL (default is https://api.siliconflow.cn/v1)
# SILICONFLOW_API_BASE=https://api.siliconflow.cn/v1

# Hugging Face — free inference API
# https://huggingface.co/settings/tokens → New token → Read permissions
# Note: Token must have permission to call Inference Providers on behalf of your organization
HUGGINGFACE_API_KEY=your_token_here

# Cloudflare Workers AI — 10k requests/day free
# https://dash.cloudflare.com/profile/api-tokens → Create Custom Token → Zone:Workers AI:Edit
# Account ID can be found in Cloudflare dashboard sidebar
CLOUDFLARE_API_KEY=your_token_here
CLOUDFLARE_ACCOUNT_ID=your_account_id_here

# OpenRouter — free models available, no billing required
# https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-your_key_here
